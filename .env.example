# PostgreSQL
POSTGRES_DB=mcpmanager
POSTGRES_USER=mcpmanager
POSTGRES_PASSWORD=changeme

# Ollama (LLM + embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SUMMARY_MODEL=llama3.1

# GitHub token (optional, increases API rate limits)
GITHUB_TOKEN=

# Google OAuth (optional, for admin login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAIL=

# JWT secret for session tokens
JWT_SECRET=changeme-random-secret
