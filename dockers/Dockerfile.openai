# ============================================================
# Agent Worker Image — OpenAI
# Communication : stdin (Task JSON) / stdout (Events JSON)
# Config        : volumes montes + variables d'environnement
# ============================================================

FROM python:3.11-slim

# --- Dependances systeme ---
RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# --- Utilisateur non-root ---
RUN useradd -m -u 1001 -s /bin/bash agent

# --- OpenAI SDK ---
RUN pip install --no-cache-dir openai

# --- Workspace ---
WORKDIR /workspace
RUN chown agent:agent /workspace

# --- Entrypoint ---
COPY --chown=agent:agent entrypoint.openai.sh /usr/local/bin/entrypoint.openai.sh
RUN chmod +x /usr/local/bin/entrypoint.openai.sh

USER agent

# Variables d'environnement runtime
# Injectees via docker run -e
ENV OPENAI_API_KEY=""
ENV OPENAI_MODEL="gpt-4o"
ENV AGENT_ROLE="worker"
ENV AGENT_MAX_TOKENS="4096"

ENTRYPOINT ["/usr/local/bin/entrypoint.openai.sh"]
