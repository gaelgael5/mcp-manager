# ============================================================
# Agent Worker Image — Claude Code
# Communication : stdin (Task JSON) / stdout (Events JSON)
# Config        : volumes montés + variables d'environnement
# ============================================================

FROM node:20-slim

# --- Dépendances système ---
RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# --- Utilisateur non-root ---
RUN useradd -m -u 1001 -s /bin/bash agent

# --- Claude Code CLI ---
RUN npm install -g @anthropic-ai/claude-code

# --- Workspace ---
WORKDIR /workspace
RUN chown agent:agent /workspace

# --- Répertoire de config Claude ---
# Les skills/CLAUDE.md sont montés ici au runtime
RUN mkdir -p /home/agent/.claude && \
    chown -R agent:agent /home/agent/.claude

# --- Entrypoint ---
COPY --chown=agent:agent entrypoint.claude-code.sh /usr/local/bin/entrypoint.claude-code.sh
RUN chmod +x /usr/local/bin/entrypoint.claude-code.sh

USER agent

# Variables d'environnement runtime
# Injectées via docker run -e
ENV ANTHROPIC_API_KEY=""
ENV AGENT_ROLE="worker"
ENV AGENT_MAX_TURNS="10"
ENV AGENT_ALLOWED_TOOLS="Read,Write,Edit,Bash(git *),Bash(pytest *)"
ENV CLAUDE_HOME=/home/agent/.claude

ENTRYPOINT ["/usr/local/bin/entrypoint.claude-code.sh"]